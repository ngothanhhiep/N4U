<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang tin điện tử
    </title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-people-fill me-2"></i><%= title %>
            </div>
            <div class="card-body">
                <div class="card-body table-responsive">
                    <a href="/taikhoan/them" class="btn btn-primary mb-2"><i class="bi bi-plus-lg"></i> Thêm mới</a>
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th width="5%" class="text-center">#</th>
                                <th>Họ và tên</th>
                                <th>Email</th>
                                <th width="10%" class="text-center">Hình ảnh</th>
                                <th>Tên đăng nhập</th>
                                <th>Quyền hạn</th>
                                <th class="text-center">Trạng thái</th>
                                <th width="5%" class="text-center">Sửa</th>
                                <th width="5%" class="text-center">Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt = ((currentPage || 1) - 1) * (pageSize || 20) + 1; %>
                            <% taikhoan.forEach(tk=> { %>
                                <tr>
                                    <td class="align-middle text-center">
                                        <%= stt++ %>
                                    </td>
                                    <td class="align-middle fw-bold">
                                        <%= tk.HoVaTen %>
                                    </td>
                                    <td class="align-middle">
                                        <%= tk.Email %>
                                    </td>
                                    <td class="align-middle text-center">
                                        <% if(tk.HinhAnh) { %>
                                            <img src="<%= tk.HinhAnh %>" 
                                                 alt="Avatar" 
                                                 class="rounded-circle shadow-sm" 
                                                 style="width: 40px; height: 40px; object-fit: cover; border: 1px solid #eee;">
                                        <% } else { %>
                                            <i class="bi bi-person-circle fs-4 text-secondary"></i>
                                        <% } %>
                                    </td>
                                    <td class="align-middle">
                                        <code><%= tk.TenDangNhap %></code>
                                    </td>
                                    <td class="align-middle">
                                        <span class="badge <%= tk.QuyenHan === 'admin' ? 'bg-danger' : 'bg-info text-dark' %>">
                                            <%= tk.QuyenHan %>
                                        </span>
                                    </td>
                                    <td class="align-middle text-center">
                                        <% if(tk.KichHoat==1) { %>
                                            <i class="bi bi-check-circle-fill text-success" title="Đang hoạt động"></i>
                                        <% } else { %>
                                            <i class="bi bi-x-circle-fill text-danger" title="Bị khóa"></i>
                                        <% } %>
                                    </td>
                                    <td class="align-middle text-center">
                                        <a href="/taikhoan/sua/<%= tk._id %>" class="btn btn-outline-primary btn-sm border-0">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    </td>
                                    <td class="align-middle text-center">
                                        <a href="/taikhoan/xoa/<%= tk._id %>"
                                           class="btn btn-outline-danger btn-sm border-0"
                                           onclick="return confirm('Bạn có muốn xóa tài khoản <%= tk.HoVaTen %> không?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                        <div class="text-muted small">
                            Tổng: <strong><%= totalItems || 0 %></strong> tài khoản • Trang <%= currentPage || 1 %>/<%= totalPages || 1 %>
                        </div>

                        <% if ((totalPages || 1) > 1) { %>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                                    </li>
                                    <% for(let i = 1; i <= totalPages; i++) { %>
                                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                            <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                                    </li>
                                </ul>
                            </nav>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript')%>
</body>
</html>