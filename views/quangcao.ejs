<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Quản trị</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-megaphone-fill"></i> <%= title %>
            </div>
            <div class="card-body table-responsive">
                <a href="/quangcao/them" class="btn btn-primary mb-3"><i class="bi bi-plus-lg"></i> Thêm mới</a>

                <table class="table table-bordered table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="5%">#</th>
                            <th width="22%">Tên quảng cáo</th>
                            <th width="28%">Hình ảnh</th>
                            <th>Link quảng cáo</th>
                            <th width="6%">Sửa</th>
                            <th width="6%">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt = ((currentPage || 1) - 1) * (pageSize || 20) + 1; %>
                        <% if (quangcao && quangcao.length > 0) { %>
                            <% quangcao.forEach(item => { %>
                                <tr>
                                    <td class="align-middle"><%= stt++ %></td>
                                    <td class="align-middle"><%= item.TenQuangCao %></td>
                                    <td class="align-middle">
                                        <% if (item.HinhAnh) { %>
                                            <img src="<%- item.HinhAnh %>" alt="<%= item.TenQuangCao %>" class="img-fluid rounded"
                                                 style="max-height: 90px; object-fit: cover;" onerror="this.src='/images/noimage.png'" />
                                        <% } else { %>
                                            <span class="text-muted small">Không có hình</span>
                                        <% } %>
                                    </td>
                                    <td class="align-middle">
                                        <% if (item.LinkQuangCao) { %>
                                            <a href="<%= item.LinkQuangCao %>" target="_blank" rel="noopener noreferrer">
                                                <%= item.LinkQuangCao %>
                                            </a>
                                        <% } else { %>
                                            <span class="text-muted small">Không có link</span>
                                        <% } %>
                                    </td>
                                    <td class="align-middle text-center">
                                        <a href="/quangcao/sua/<%= item._id %>"><i class="bi bi-pencil-square"></i></a>
                                    </td>
                                    <td class="align-middle text-center">
                                        <a href="/quangcao/xoa/<%= item._id %>" class="text-danger"
                                           onclick="return confirm('Bạn có muốn xóa quảng cáo này không?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted py-3">Chưa có quảng cáo nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                    <div class="text-muted small">
                        Tổng: <%= totalItems || 0 %> quảng cáo • Trang <%= currentPage || 1 %>/<%= totalPages || 1 %>
                    </div>

                    <% if ((totalPages || 1) > 1) { %>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                                </li>
                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript') %>
</body>

</html>
