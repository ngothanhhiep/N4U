<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
    <style>
        .article-card { transition: transform 0.2s, box-shadow 0.2s; border: none; }
        .article-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important; }
        mark { background-color: #fff3cd; padding: 0 2px; border-radius: 2px; font-weight: 600; }
        .article-thumb-fixed { width: 100%; height: 180px; object-fit: cover; }

        @media (min-width: 992px) {
            .smart-sidebar-container {
                position: relative;
            }

            .search-sidebar-sticky {
                position: relative;
            }
        }
    </style>
</head>

<body class="bg-light">
    <div class="container bg-white shadow-sm px-0">
        <%- include('navbar') %>

        <div class="container py-4">

            <!-- Thanh tìm kiếm lớn -->
            <div class="mb-4">
                <form action="/timkiem" method="get" class="d-flex gap-2">
                    <input
                        type="search"
                        name="tukhoa"
                        value="<%= tukhoa %>"
                        class="form-control form-control-lg shadow-sm"
                        placeholder="Nhập từ khóa tìm kiếm..."
                        maxlength="200"
                        required
                    />
                    <button type="submit" class="btn btn-primary btn-lg px-4 shadow-sm">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>

            <!-- Bộ lọc -->
            <% if (tukhoa) { %>
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light fw-bold">
                        <i class="bi bi-funnel me-2"></i>Lọc kết quả
                        <% if (filters.chuDeFilter || filters.tacGiaFilter || filters.tuNgay || filters.denNgay) { %>
                            <a href="/timkiem?tukhoa=<%= encodeURIComponent(tukhoa) %>" class="float-end btn btn-sm btn-outline-danger">
                                <i class="bi bi-x-circle me-1"></i>Xóa bộ lọc
                            </a>
                        <% } %>
                    </div>
                    <div class="card-body">
                        <form action="/timkiem" method="get" class="row g-3">
                            <!-- Từ khóa (ẩn) -->
                            <input type="hidden" name="tukhoa" value="<%= tukhoa %>">

                            <!-- Chủ đề -->
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Chủ đề</label>
                                <select name="chuDe" class="form-select form-select-sm">
                                    <option value="">-- Tất cả --</option>
                                    <% if (chuyenmuc && chuyenmuc.length > 0) { %>
                                        <% chuyenmuc.forEach(cm => { %>
                                            <option value="<%= cm._id %>" <%= filters.chuDeFilter === cm._id.toString() ? 'selected' : '' %>>
                                                <%= cm.TenChuDe %>
                                            </option>
                                        <% }); %>
                                    <% } %>
                                </select>
                            </div>

                            <!-- Tác giả -->
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Tác giả</label>
                                <select name="tacGia" class="form-select form-select-sm">
                                    <option value="">-- Tất cả --</option>
                                    <% if (taikhoan && taikhoan.length > 0) { %>
                                        <% taikhoan.forEach(tk => { %>
                                            <option value="<%= tk._id %>" <%= filters.tacGiaFilter === tk._id.toString() ? 'selected' : '' %>>
                                                <%= tk.HoVaTen || tk.TenDangNhap %>
                                            </option>
                                        <% }); %>
                                    <% } %>
                                </select>
                            </div>

                            <!-- Ngày viết từ -->
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Từ ngày</label>
                                <input type="date" name="tuNgay" class="form-control form-control-sm" value="<%= filters.tuNgay %>">
                            </div>

                            <!-- Ngày viết đến -->
                            <div class="col-md-3">
                                <label class="form-label small fw-bold">Đến ngày</label>
                                <input type="date" name="denNgay" class="form-control form-control-sm" value="<%= filters.denNgay %>">
                            </div>

                            <!-- Nút lọc -->
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-funnel me-1"></i>Lọc
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            <% } %>

            <!-- Header kết quả -->
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2 flex-wrap gap-2">
                <h5 class="fw-bold mb-0">
                    <% if (tukhoa) { %>
                        <i class="bi bi-search text-primary me-2"></i>
                        Kết quả tìm kiếm: <span class="text-primary">"<%= tukhoa %>"</span>
                    <% } else { %>
                        <i class="bi bi-search text-muted me-2"></i>Tìm kiếm
                    <% } %>
                </h5>
                <% if (tukhoa) { %>
                    <span class="text-muted small">
                        Tìm thấy <strong><%= totalItems || 0 %></strong> bài viết
                        <% if ((totalPages || 1) > 1) { %>
                            &bull; Trang <%= currentPage || 1 %>/<%= totalPages %>
                        <% } %>
                    </span>
                <% } %>
            </div>

            <div class="row g-4">

                <!-- Cột trái: kết quả -->
                <div class="col-lg-8">
                    <% if (!tukhoa) { %>
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-search fs-1 d-block mb-3"></i>
                            <p>Nhập từ khóa để tìm kiếm bài viết.</p>
                        </div>
                    <% } else if (baiviet && baiviet.length > 0) { %>

                        <div class="d-flex flex-column gap-3">
                            <% baiviet.forEach(bv => { %>
                                <div class="card article-card shadow-sm">
                                    <div class="row g-0 align-items-stretch">
                                        <div class="col-md-4">
                                            <img src="<%- bv.displayImage || bv.HinhAnh || '/images/noimage.png' %>"
                                                 class="img-fluid rounded-start article-thumb-fixed"
                                                 onerror="this.src='/images/noimage.png'"
                                                 alt="<%= bv.TieuDe %>">
                                        </div>
                                        <div class="col-md-8">
                                            <div class="card-body d-flex flex-column h-100">
                                                <span class="badge bg-info-subtle text-primary border border-info-subtle text-uppercase mb-2" style="font-size: 0.7rem; width: fit-content;">
                                                    <i class="bi bi-tag-fill me-1"></i><%= bv.ChuDe ? bv.ChuDe.TenChuDe : 'N/A' %>
                                                </span>

                                                <h5 class="card-title mb-2">
                                                    <a href="/baiviet/<%= bv._id %>" class="text-decoration-none text-dark fw-bold">
                                                        <%- bv.highlightedTitle || bv.TieuDe %>
                                                    </a>
                                                </h5>

                                                <p class="card-text text-muted small flex-grow-1">
                                                    <%- bv.highlightedSummary || (bv.TomTat ? bv.TomTat.substring(0, 150) + '...' : '') %>
                                                </p>

                                                <div class="mt-auto d-flex justify-content-between align-items-center border-top pt-2 small text-muted">
                                                    <div>
                                                        <i class="bi bi-person-circle text-primary me-1"></i>
                                                        <span class="fw-medium text-dark">
                                                            <%= bv.TaiKhoan ? bv.TaiKhoan.HoVaTen : 'Ẩn danh' %>
                                                        </span>
                                                    </div>
                                                    <div class="text-end">
                                                        <i class="bi bi-calendar3 me-1"></i><%= new Date(bv.NgayDang).toLocaleDateString('vi-VN') %>
                                                        <span class="mx-1">|</span>
                                                        <i class="bi bi-eye me-1"></i><%= bv.LuotXem %>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>

                        <!-- Phân trang -->
                        <% if ((totalPages || 1) > 1) { %>
                            <nav class="mt-4">
                                <ul class="pagination justify-content-center">
                                    <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                        <a class="page-link" href="/timkiem?tukhoa=<%= encodeURIComponent(tukhoa) %>&chuDe=<%= filters.chuDeFilter %>&tacGia=<%= filters.tacGiaFilter %>&tuNgay=<%= filters.tuNgay %>&denNgay=<%= filters.denNgay %>&page=<%= currentPage - 1 %>">
                                            <i class="bi bi-chevron-left"></i> Trước
                                        </a>
                                    </li>
                                    <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                            <a class="page-link" href="/timkiem?tukhoa=<%= encodeURIComponent(tukhoa) %>&chuDe=<%= filters.chuDeFilter %>&tacGia=<%= filters.tacGiaFilter %>&tuNgay=<%= filters.tuNgay %>&denNgay=<%= filters.denNgay %>&page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                        <a class="page-link" href="/timkiem?tukhoa=<%= encodeURIComponent(tukhoa) %>&chuDe=<%= filters.chuDeFilter %>&tacGia=<%= filters.tacGiaFilter %>&tuNgay=<%= filters.tuNgay %>&denNgay=<%= filters.denNgay %>&page=<%= currentPage + 1 %>">
                                            Sau <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        <% } %>

                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="bi bi-file-earmark-x fs-1 d-block mb-3 text-muted"></i>
                            <h6 class="text-muted">Không tìm thấy bài viết nào cho từ khóa <strong>"<%= tukhoa %>"</strong>.</h6>
                            <p class="text-muted small mt-2">Thử tìm với từ khóa khác hoặc kiểm tra chính tả.</p>
                            <a href="/tinmoi" class="btn btn-outline-primary btn-sm mt-2">
                                <i class="bi bi-arrow-left me-1"></i>Xem bài viết mới nhất
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Cột phải: sidebar -->
                <div class="col-lg-4 smart-sidebar-container" data-sticky-breakpoint="992">
                    <div class="search-sidebar-sticky">

                    <!-- Chủ đề phổ biến -->
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header bg-white fw-bold border-0 pt-3">
                            <i class="bi bi-grid-fill text-primary me-2"></i>Chủ đề phổ biến
                        </div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2">
                                <% if (chuyenmuc && chuyenmuc.length > 0) { %>
                                    <% chuyenmuc.forEach(cm => { %>
                                        <a href="/chude/<%= cm._id %>" class="btn btn-sm btn-outline-secondary rounded-pill">
                                            <%= cm.TenChuDe %>
                                        </a>
                                    <% }); %>
                                <% } else { %>
                                    <span class="text-muted small">Chưa có chủ đề nào.</span>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Xem nhiều nhất -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white fw-bold border-0 pt-3">
                            <i class="bi bi-fire text-danger me-2"></i>Xem nhiều nhất
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                <% if (xemnhieu && xemnhieu.length > 0) { %>
                                    <% xemnhieu.forEach((xn, index) => { %>
                                        <li class="list-group-item py-3 article-card border-0">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3">
                                                    <span class="fs-5 fw-bold text-secondary-emphasis">
                                                        <%= (index + 1) < 10 ? '0' + (index + 1) : (index + 1) %>
                                                    </span>
                                                </div>
                                                <div class="flex-shrink-0 me-3">
                                                    <img src="<%- xn.HinhAnh || '/images/noimage.png' %>"
                                                         alt="<%= xn.TieuDe %>"
                                                         class="rounded"
                                                         style="width: 60px; height: 60px; object-fit: cover;"
                                                         onerror="this.src='/images/noimage.png'">
                                                </div>
                                                <div class="flex-grow-1">
                                                    <h6 class="mb-1 fw-bold" style="line-height: 1.4;">
                                                        <a href="/baiviet/<%= xn._id %>"
                                                           class="text-decoration-none text-dark small d-block"
                                                           style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                                            <%= xn.TieuDe %>
                                                        </a>
                                                    </h6>
                                                    <small class="text-muted" style="font-size: 0.75rem;">
                                                        <i class="bi bi-eye me-1"></i><%= xn.LuotXem.toLocaleString('vi-VN') %> lượt xem
                                                    </small>
                                                </div>
                                            </div>
                                        </li>
                                    <% }); %>
                                <% } else { %>
                                    <li class="list-group-item text-center text-muted small py-3">
                                        Chưa có dữ liệu
                                    </li>
                                <% } %>
                            </ul>
                        </div>
                    </div>

                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript')%>
    <script>
        (function () {
            const container = document.querySelector('.smart-sidebar-container');
            const sidebar = document.querySelector('.search-sidebar-sticky');
            const footer = document.querySelector('footer') || document.querySelector('.footer') || document.querySelector('body > .container > div:last-child');
            const headerOffset = 84;
            const viewportGap = 16;
            const breakpoint = Number((container && container.dataset.stickyBreakpoint) || 992);
            let lastScrollY = window.scrollY;

            if (!container || !sidebar) return;

            const resetSidebarStyle = () => {
                sidebar.style.position = '';
                sidebar.style.top = '';
                sidebar.style.left = '';
                sidebar.style.right = '';
            };

            const updateSmartSticky = () => {
                if (window.innerWidth < breakpoint) {
                    resetSidebarStyle();
                    return;
                }

                const currentScrollY = window.scrollY;
                const isScrollingDown = currentScrollY > lastScrollY;
                lastScrollY = currentScrollY;

                const containerRect = container.getBoundingClientRect();
                const containerTop = currentScrollY + containerRect.top;
                const containerHeight = container.offsetHeight;
                const sidebarHeight = sidebar.offsetHeight;
                const footerTop = footer
                    ? currentScrollY + footer.getBoundingClientRect().top
                    : Number.POSITIVE_INFINITY;

                const minTop = containerTop;
                const maxTop = Math.min(containerTop + containerHeight, footerTop - viewportGap) - sidebarHeight;

                const desiredTop = (isScrollingDown && sidebarHeight < (window.innerHeight - headerOffset))
                    ? currentScrollY + window.innerHeight - sidebarHeight - viewportGap
                    : currentScrollY + headerOffset;

                const clampedTop = Math.max(minTop, Math.min(desiredTop, maxTop));

                sidebar.style.position = 'absolute';
                sidebar.style.top = `${Math.max(0, clampedTop - containerTop)}px`;
                sidebar.style.left = '0';
                sidebar.style.right = '0';
            };

            window.addEventListener('scroll', updateSmartSticky, { passive: true });
            window.addEventListener('resize', updateSmartSticky);
            updateSmartSticky();
        })();
    </script>
</body>

</html>
