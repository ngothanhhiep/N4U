<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Quản trị</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3 mb-3 border-0 shadow-sm">
            <div class="card-header fw-bold text-uppercase bg-white d-flex align-items-center justify-content-between">
                <span><i class="bi bi-flag-fill text-danger me-2"></i><%= title %></span>
            </div>
            <div class="card-body">
                <!-- Thống kê nhanh -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="card h-100 border-0 text-white" style="background-color: #f39c12;">
                            <div class="card-body py-3">
                                <div class="small"><i class="bi bi-hourglass-split me-1"></i>Chờ xử lý</div>
                                <div class="fs-4 fw-bold"><%= thongke.choDuyet %></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card h-100 border-0 text-white" style="background-color: #27ae60;">
                            <div class="card-body py-3">
                                <div class="small"><i class="bi bi-check-circle me-1"></i>Đã xử lý</div>
                                <div class="fs-4 fw-bold"><%= thongke.daXuLy %></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card h-100 border-0 text-white" style="background-color: #7f8c8d;">
                            <div class="card-body py-3">
                                <div class="small"><i class="bi bi-x-circle me-1"></i>Từ chối</div>
                                <div class="fs-4 fw-bold"><%= thongke.tuChoi %></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card h-100 border-0 text-white" style="background-color: #2980b9;">
                            <div class="card-body py-3">
                                <div class="small"><i class="bi bi-flag me-1"></i>Tổng báo cáo</div>
                                <div class="fs-4 fw-bold"><%= thongke.tongSo %></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bộ lọc -->
                <form method="GET" action="/baocao" class="row g-2 mb-4 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Trạng thái</label>
                        <select name="trangThai" class="form-select form-select-sm">
                            <option value="" <%- filter.trangThai === '' ? 'selected' : '' %>>-- Tất cả --</option>
                            <option value="0" <%- filter.trangThai === 0 ? 'selected' : '' %>>Chờ xử lý</option>
                            <option value="1" <%- filter.trangThai === 1 ? 'selected' : '' %>>Đã xử lý</option>
                            <option value="2" <%- filter.trangThai === 2 ? 'selected' : '' %>>Từ chối</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Loại đối tượng</label>
                        <select name="loai" class="form-select form-select-sm">
                            <option value="" <%- filter.loai === '' ? 'selected' : '' %>>-- Tất cả --</option>
                            <option value="BaiViet" <%- filter.loai === 'BaiViet' ? 'selected' : '' %>>Bài viết</option>
                            <option value="BinhLuan" <%- filter.loai === 'BinhLuan' ? 'selected' : '' %>>Bình luận</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-funnel me-1"></i>Lọc
                        </button>
                    </div>
                </form>

                <!-- Bảng danh sách báo cáo -->
                <% if (danhSachBaoCao.length === 0) { %>
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1"></i>
                        <p class="mt-2">Không có báo cáo nào.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px">#</th>
                                    <th>Người báo cáo</th>
                                    <th>Loại</th>
                                    <th>Đối tượng bị báo cáo</th>
                                    <th>Lý do</th>
                                    <th>Mô tả</th>
                                    <th>Ngày gửi</th>
                                    <th style="width:110px">Trạng thái</th>
                                    <th style="width:110px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% danhSachBaoCao.forEach(function(bc, i) { %>
                                <tr>
                                    <td class="text-muted small"><%= (phanTrang.trangHienTai - 1) * 15 + i + 1 %></td>

                                    <!-- Người báo cáo -->
                                    <td>
                                        <% if (bc.NguoiBaoCao) { %>
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="<%= bc.NguoiBaoCao.HinhAnh || '/images/default-avatar.png' %>"
                                                     alt="avatar"
                                                     class="rounded-circle"
                                                     style="width:32px;height:32px;object-fit:cover;">
                                                <span class="small"><%= bc.NguoiBaoCao.HoVaTen %></span>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted small">Ẩn danh</span>
                                        <% } %>
                                    </td>

                                    <!-- Loại -->
                                    <td>
                                        <% if (bc.LoaiDoiTuong === 'BaiViet') { %>
                                            <span class="badge bg-primary">Bài viết</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Bình luận</span>
                                        <% } %>
                                    </td>

                                    <!-- Đối tượng bị báo cáo -->
                                    <td class="small">
                                        <% if (bc.LoaiDoiTuong === 'BaiViet' && bc.BaiViet) { %>
                                            <a href="/baiviet/<%= bc.BaiViet._id %>" target="_blank" class="text-decoration-none">
                                                <%= bc.BaiViet.TieuDe.substring(0, 60) %><%= bc.BaiViet.TieuDe.length > 60 ? '...' : '' %>
                                            </a>
                                            <% if (bc.BaiViet.KiemDuyet === 0) { %>
                                                <span class="badge bg-warning text-dark ms-1">Chờ duyệt</span>
                                            <% } %>
                                        <% } else if (bc.LoaiDoiTuong === 'BinhLuan' && bc.BinhLuan) { %>
                                            <span class="text-muted fst-italic">"<%= bc.BinhLuan.NoiDung.substring(0, 60) %><%= bc.BinhLuan.NoiDung.length > 60 ? '...' : '' %>"</span>
                                            <% if (bc.BinhLuan.BaiViet) { %>
                                                <br><span class="text-muted" style="font-size:0.75rem;">
                                                    Trong: <a href="/baiviet/<%= bc.BinhLuan.BaiViet._id %>" target="_blank" class="text-decoration-none"><%= bc.BinhLuan.BaiViet.TieuDe.substring(0,50) %></a>
                                                </span>
                                            <% } %>
                                        <% } else { %>
                                            <span class="text-danger small">Nội dung đã bị xóa</span>
                                        <% } %>
                                    </td>

                                    <!-- Lý do -->
                                    <td>
                                        <% const lyDoMap = {
                                            'NoiDungNhayCam': { label: 'Nội dung nhạy cảm', color: 'warning' },
                                            'NgonNguThoTuc': { label: 'Ngôn ngữ thô tục', color: 'danger' },
                                            'CongKichThuDich': { label: 'Công kích thù địch', color: 'danger' },
                                            'TinGiaMaoLua': { label: 'Tin giả / Lừa đảo', color: 'dark' },
                                            'Khac': { label: 'Khác', color: 'secondary' }
                                        }; %>
                                        <% const lyDo = lyDoMap[bc.LyDo] || { label: bc.LyDo, color: 'secondary' }; %>
                                        <span class="badge bg-<%= lyDo.color %>"><%= lyDo.label %></span>
                                    </td>

                                    <!-- Mô tả -->
                                    <td class="small text-muted">
                                        <%= bc.MoTa ? bc.MoTa.substring(0, 80) + (bc.MoTa.length > 80 ? '...' : '') : '—' %>
                                    </td>

                                    <!-- Ngày gửi -->
                                    <td class="small text-nowrap text-muted">
                                        <%= new Date(bc.createdAt).toLocaleDateString('vi-VN') %>
                                    </td>

                                    <!-- Trạng thái -->
                                    <td class="text-center">
                                        <% if (bc.TrangThai === 0) { %>
                                            <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                        <% } else if (bc.TrangThai === 1) { %>
                                            <span class="badge bg-success">Đã xử lý</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Từ chối</span>
                                        <% } %>
                                    </td>

                                    <!-- Thao tác -->
                                    <td class="text-center">
                                        <% if (bc.TrangThai === 0) { %>
                                            <!-- Nút xử lý -->
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success mb-1"
                                                    title="Xác nhận vi phạm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalXuLy"
                                                    data-id="<%= bc._id %>"
                                                    data-trang-thai="1">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <!-- Nút từ chối -->
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary mb-1"
                                                    title="Từ chối (không vi phạm)"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalXuLy"
                                                    data-id="<%= bc._id %>"
                                                    data-trang-thai="2">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        <% } %>
                                        <% if (session.QuyenHan === 'admin') { %>
                                            <form action="/baocao/<%= bc._id %>/xoa" method="POST"
                                                  onsubmit="return confirm('Xóa báo cáo này?')" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Phân trang -->
                    <% if (phanTrang.tongTrang > 1) { %>
                        <nav class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center">
                                <li class="page-item <%- phanTrang.trangHienTai <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?trang=<%= phanTrang.trangHienTai - 1 %>&trangThai=<%= filter.trangThai %>&loai=<%= filter.loai %>">«</a>
                                </li>
                                <% for (let p = 1; p <= phanTrang.tongTrang; p++) { %>
                                    <li class="page-item <%- p === phanTrang.trangHienTai ? 'active' : '' %>">
                                        <a class="page-link" href="?trang=<%= p %>&trangThai=<%= filter.trangThai %>&loai=<%= filter.loai %>"><%= p %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%- phanTrang.trangHienTai >= phanTrang.tongTrang ? 'disabled' : '' %>">
                                    <a class="page-link" href="?trang=<%= phanTrang.trangHienTai + 1 %>&trangThai=<%= filter.trangThai %>&loai=<%= filter.loai %>">»</a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                <% } %>

            </div>
        </div>
        <%- include('footer') %>
    </div>

    <!-- Modal xử lý báo cáo -->
    <div class="modal fade" id="modalXuLy" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="formXuLy" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-shield-check me-2"></i>Xử lý báo cáo</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="TrangThai" id="inputTrangThai" />
                        <div id="labelXuLy" class="alert mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ghi chú xử lý <span class="text-muted fw-normal">(tùy chọn)</span></label>
                            <textarea name="GhiChuAdmin" class="form-control" rows="3"
                                      placeholder="Mô tả hành động đã thực hiện, ví dụ: đã ẩn bài viết, cảnh cáo người dùng..."
                                      maxlength="300"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary" id="btnXacNhan">Xác nhận</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('javascript') %>
    <script>
        const modalXuLy = document.getElementById('modalXuLy');
        if (modalXuLy) {
            modalXuLy.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                const id = btn.getAttribute('data-id');
                const trangThai = btn.getAttribute('data-trang-thai');

                document.getElementById('formXuLy').action = '/baocao/' + id + '/xuly';
                document.getElementById('inputTrangThai').value = trangThai;

                const label = document.getElementById('labelXuLy');
                const btnXacNhan = document.getElementById('btnXacNhan');

                if (trangThai === '1') {
                    label.className = 'alert alert-success mb-3';
                    label.textContent = 'Xác nhận báo cáo này là VI PHẠM và xử lý.';
                    btnXacNhan.className = 'btn btn-success';
                } else {
                    label.className = 'alert alert-secondary mb-3';
                    label.textContent = 'Từ chối báo cáo này (nội dung không vi phạm).';
                    btnXacNhan.className = 'btn btn-secondary';
                }
            });
        }
    </script>
</body>

</html>
