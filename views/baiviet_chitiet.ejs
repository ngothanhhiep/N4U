<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
    <style>
        @media (min-width: 992px) {
            .smart-sidebar-container {
                position: relative;
            }

            .detail-sidebar-sticky {
                position: relative;
            }
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
            border-radius: 10px;
            overflow: hidden;
            background: #000;
        }

        .video-wrapper iframe,
        .video-wrapper video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }

        /* Ảnh và media trong nội dung bài viết tự co vừa cột, không lố sang sidebar */
        .article-content img,
        .article-content video,
        .article-content iframe,
        .article-content embed,
        .article-content object {
            max-width: 100% !important;
            width: auto !important;
            height: auto !important;
        }

        .article-content figure {
            max-width: 100% !important;
            margin-left: 0;
            margin-right: 0;
        }

        .article-content table {
            max-width: 100%;
            overflow-x: auto;
            display: block;
        }
    </style>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3 shadow-sm">
            <div class="card-header bg-white fw-bold text-uppercase">
                <i class="bi bi-file-earmark-text"></i> Chi tiết bài viết
            </div>
            <div class="card-body">
                <% if (baiviet) { %>
                    <div class="row g-4">
                        <div class="col-lg-8">
                            <div class="mb-3">
                                <h2 class="text-primary"><%= baiviet.TieuDe %></h2>
                                <p class="text-muted small">
                                    <i class="bi bi-tag"></i> Chủ đề: <span class="badge bg-info text-dark"><%= baiviet.ChuDe ? baiviet.ChuDe.TenChuDe : 'N/A' %></span> |
                                    <span class="ms-1">
                                        <% if(baiviet.TaiKhoan) { %>
                                            <img src="<%= baiviet.TaiKhoan.HinhAnh || '/images/default-avatar.png' %>" 
                                                class="rounded-circle" style="width: 24px; height: 24px; object-fit: cover;">
                                            <a href="/taikhoan/chitiet/<%= baiviet.TaiKhoan._id %>" class="text-decoration-none fw-bold ms-1">
                                                <%= tacGia %>
                                            </a>
                                        <% } else { %>
                                            <strong><%= tacGia || 'N/A' %></strong>
                                        <% } %>
                                    </span> |
                                    <i class="bi bi-calendar3"></i> Ngày đăng: <%= new Date(baiviet.NgayDang).toLocaleDateString('vi-VN') %> |
                                    <i class="bi bi-eye"></i> Lượt xem: <%= baiviet.LuotXem %>
                                </p>
                                <% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger mb-3"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalBaoCao"
                                            data-loai="BaiViet"
                                            data-id="<%= baiviet._id %>">
                                        <i class="bi bi-flag me-1"></i>Báo cáo vi phạm
                                    </button>
                                <% } %>
                                <hr>
                                <% if(baiviet.displayImage || baiviet.HinhAnh) { %>
                                    <div class="text-center mb-4">
                                        <img src="<%- baiviet.displayImage || baiviet.HinhAnh || '/images/noimage.png' %>" class="img-fluid rounded shadow-sm" style="max-height: 400px; width: 100%; object-fit: cover;" onerror="this.src='/images/noimage.png'">
                                    </div>
                                <% } %>

                                <% if (baiviet.VideoURL) { %>
                                    <div class="mb-4">
                                        <div class="video-wrapper">
                                            <% if (baiviet.VideoURL.includes('youtube.com/embed/')) { %>
                                                <iframe src="<%= baiviet.VideoURL %>" title="Video bài viết" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                                            <% } else if (baiviet.VideoURL.match(/\.(mp4|webm|ogg)(\?.*)?$/i)) { %>
                                                <video controls preload="metadata">
                                                    <source src="<%= baiviet.VideoURL %>">
                                                    Trình duyệt của bạn không hỗ trợ phát video.
                                                </video>
                                            <% } else { %>
                                                <div class="h-100 d-flex flex-column justify-content-center align-items-center text-white p-3">
                                                    <i class="bi bi-film fs-1 mb-2"></i>
                                                    <a href="<%= baiviet.VideoURL %>" target="_blank" rel="noopener noreferrer" class="btn btn-light btn-sm">
                                                        Mở video
                                                    </a>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                <% } %>

                                <p class="lead text-secondary"><strong>Tóm tắt:</strong> <%= baiviet.TomTat %></p>
                                <div class="mt-4 article-content">
                                    <%- baiviet.NoiDung %>
                                </div>
                            </div>

                            <hr class="mt-5">

                            <div class="mt-4" id="binh-luan">
                                <h4 class="mb-4"><i class="bi bi-chat-left-dots"></i> Bình luận (<%= totalComments || 0 %>)</h4>

                                <% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
                                    <div class="card mb-4 bg-light">
                                        <div class="card-body">
                                            <form action="/binhluan/them" method="post">
                                                <input type="hidden" name="BaiViet" value="<%= baiviet._id %>">
                                                <div class="mb-3">
                                                    <label for="NoiDung" class="form-label fw-bold">Để lại ý kiến của bạn:</label>
                                                    <textarea name="NoiDung" class="form-control" rows="3" placeholder="Chia sẻ suy nghĩ của bạn về bài viết này..." required></textarea>
                                                </div>
                                                <div class="text-end">
                                                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Gửi bình luận</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                <% } else { %>
                                    <div class="alert alert-warning">
                                        <i class="bi bi-exclamation-triangle"></i> Vui lòng <a href="/dangnhap" class="fw-bold">đăng nhập</a> để gửi bình luận.
                                    </div>
                                <% } %>

                                <div class="comment-list">
                                    <% if(binhluan && binhluan.length > 0) { %>
                                        <% binhluan.forEach(item => { %>
                                            <div class="d-flex mb-4 p-3 border rounded shadow-xs bg-white">
                                                <div class="flex-shrink-0">
                                                    <img src="<%= (item.TaiKhoan && item.TaiKhoan.HinhAnh) ? item.TaiKhoan.HinhAnh : '/images/default-avatar.png' %>" 
                                                         class="rounded-circle border" 
                                                         style="width: 50px; height: 50px; object-fit: cover;">
                                                </div>
                                                <div class="flex-grow-1 ms-3">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <h6 class="mb-0 fw-bold"><%= item.TaiKhoan ? item.TaiKhoan.HoVaTen : 'Người dùng ẩn danh' %></h6>
                                                        <small class="text-muted"><i class="bi bi-clock"></i> <%= new Date(item.createdAt).toLocaleString('vi-VN') %></small>
                                                    </div>
                                                    <p class="mb-2 text-dark"><%= item.NoiDung %></p>
                                                    <div class="d-flex gap-3">
                                                        <a href="/binhluan/like/<%= item._id %>" 
                                                            class="btn btn-sm <%= (session.MaNguoiDung && item.LuotThich.includes(session.MaNguoiDung)) ? 'btn-primary' : 'btn-outline-primary' %>">
                                                            <i class="bi bi-hand-thumbs-up"></i> <%= item.LuotThich.length %>
                                                            </a>

                                                            <a href="/binhluan/dislike/<%= item._id %>" 
                                                            class="btn btn-sm <%= (session.MaNguoiDung && item.LuotKhongThich.includes(session.MaNguoiDung)) ? 'btn-danger' : 'btn-outline-danger' %>">
                                                            <i class="bi bi-hand-thumbs-down"></i> <%= item.LuotKhongThich.length %>
                                                            </a>
                                                        <% if(typeof session !== "undefined" && (session.QuyenHan == 'admin' || session.QuyenHan == 'maneger' || session.MaNguoiDung == (item.TaiKhoan ? item.TaiKhoan._id : null))) { %>
                                                            <a href="/binhluan/xoa/<%= item._id %>" class="btn btn-sm btn-outline-secondary border-0 ms-auto text-danger" onclick="return confirm('Xóa bình luận?')">
                                                                <i class="bi bi-trash"></i>
                                                            </a>
                                                        <% } %>
                                                        <% if(typeof session !== "undefined" && session.MaNguoiDung && session.MaNguoiDung != (item.TaiKhoan ? item.TaiKhoan._id : null)) { %>
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-secondary border-0 ms-auto text-warning"
                                                                    title="Báo cáo bình luận này"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="#modalBaoCao"
                                                                    data-loai="BinhLuan"
                                                                    data-id="<%= item._id %>">
                                                                <i class="bi bi-flag"></i>
                                                            </button>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>

                                        <% if ((totalCommentPages || 1) > 1) { %>
                                            <nav class="mt-3">
                                                <ul class="pagination pagination-sm justify-content-center">
                                                    <li class="page-item <%= currentCommentPage <= 1 ? 'disabled' : '' %>">
                                                        <a class="page-link" href="?commentPage=<%= currentCommentPage - 1 %>#binh-luan">Trước</a>
                                                    </li>
                                                    <% for(let i = 1; i <= totalCommentPages; i++) { %>
                                                        <li class="page-item <%= currentCommentPage === i ? 'active' : '' %>">
                                                            <a class="page-link" href="?commentPage=<%= i %>#binh-luan"><%= i %></a>
                                                        </li>
                                                    <% } %>
                                                    <li class="page-item <%= currentCommentPage >= totalCommentPages ? 'disabled' : '' %>">
                                                        <a class="page-link" href="?commentPage=<%= currentCommentPage + 1 %>#binh-luan">Sau</a>
                                                    </li>
                                                </ul>
                                            </nav>
                                        <% } %>
                                    <% } else { %>
                                        <p class="text-center text-muted py-4 italic">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 smart-sidebar-container" data-sticky-breakpoint="992">
                            <div class="detail-sidebar-sticky">
                                <% if (quangcao) { %>
                                    <div class="card mb-4 border-0 shadow-sm overflow-hidden">
                                        <div class="card-header bg-white fw-bold border-0 pt-3">
                                            <i class="bi bi-megaphone-fill text-warning me-2"></i>Quảng cáo ngẫu nhiên
                                        </div>
                                        <div class="card-body p-0">
                                            <% if (quangcao.LinkQuangCao) { %>
                                                <a href="<%= quangcao.LinkQuangCao %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none d-block">
                                                    <img src="<%- quangcao.HinhAnh || '/images/noimage.png' %>"
                                                         alt="<%= quangcao.TenQuangCao %>"
                                                         class="w-100"
                                                         style="max-height: 220px; object-fit: cover;"
                                                         onerror="this.src='/images/noimage.png'">
                                                    <div class="p-3">
                                                        <div class="fw-semibold text-dark"><%= quangcao.TenQuangCao %></div>
                                                    </div>
                                                </a>
                                            <% } else { %>
                                                <img src="<%- quangcao.HinhAnh || '/images/noimage.png' %>"
                                                     alt="<%= quangcao.TenQuangCao %>"
                                                     class="w-100"
                                                     style="max-height: 220px; object-fit: cover;"
                                                     onerror="this.src='/images/noimage.png'">
                                                <div class="p-3">
                                                    <div class="fw-semibold text-dark"><%= quangcao.TenQuangCao %></div>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                <% } %>

                                <div class="card border-0 shadow-sm">
                                    <div class="card-header bg-white fw-bold border-0 pt-3">
                                        <i class="bi bi-collection text-primary me-2"></i>Bài viết cùng chủ đề
                                    </div>
                                    <div class="card-body p-0">
                                        <ul class="list-group list-group-flush">
                                            <% if (baiVietCungChuDe && baiVietCungChuDe.length > 0) { %>
                                                <% baiVietCungChuDe.forEach((item, index) => { %>
                                                    <li class="list-group-item py-3">
                                                        <div class="d-flex align-items-center">
                                                            <div class="me-3 text-muted small fw-bold"><%= index + 1 %></div>
                                                            <div class="flex-shrink-0 me-3">
                                                                <img src="<%- item.displayImage || '/images/noimage.png' %>"
                                                                     alt="<%= item.TieuDe %>"
                                                                     class="rounded"
                                                                     style="width: 64px; height: 64px; object-fit: cover;"
                                                                     onerror="this.src='/images/noimage.png'">
                                                            </div>
                                                            <div class="flex-grow-1">
                                                                <a href="/baiviet/<%= item._id %>" class="text-decoration-none text-dark fw-semibold small d-block" style="line-height: 1.4;">
                                                                    <%= item.TieuDe %>
                                                                </a>
                                                                <small class="text-muted"><%= new Date(item.NgayDang).toLocaleDateString('vi-VN') %></small>
                                                            </div>
                                                        </div>
                                                    </li>
                                                <% }) %>
                                            <% } else { %>
                                                <li class="list-group-item text-center text-muted py-3">Chưa có bài viết liên quan.</li>
                                            <% } %>
                                        </ul>
                                    </div>
                                    <% if (baiviet.ChuDe && baiviet.ChuDe._id) { %>
                                        <div class="card-footer bg-white border-0">
                                            <a href="/chude/<%= baiviet.ChuDe._id %>" class="btn btn-outline-primary btn-sm w-100">
                                                Xem thêm <i class="bi bi-arrow-right ms-1"></i>
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                <% } else { %>
                    <div class="alert alert-danger text-center my-5">
                        <h4><i class="bi bi-bug"></i> Bài viết không tồn tại.</h4>
                        <a href="/" class="btn btn-outline-danger mt-3">Quay lại trang chủ</a>
                    </div>
                <% } %>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <!-- Modal báo cáo vi phạm -->
    <% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
    <div class="modal fade" id="modalBaoCao" tabindex="-1" aria-labelledby="modalBaoCaoLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="formBaoCao" action="/baocao" method="POST">
                    <input type="hidden" name="LoaiDoiTuong" id="baocaoLoai" />
                    <input type="hidden" name="DoiTuongId" id="baocaoId" />
                    <input type="hidden" name="redirectTo" id="baocaoRedirect" />
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title text-danger" id="modalBaoCaoLabel">
                            <i class="bi bi-flag-fill me-2"></i>Báo cáo vi phạm
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body pt-2">
                        <p class="text-muted small mb-3" id="baocaoMoTaDoiTuong"></p>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Lý do vi phạm <span class="text-danger">*</span></label>
                            <div class="d-grid gap-2">
                                <div class="form-check border rounded p-3">
                                    <input class="form-check-input" type="radio" name="LyDo" id="lydo1" value="NoiDungNhayCam" required>
                                    <label class="form-check-label" for="lydo1">
                                        <i class="bi bi-eye-slash text-warning me-2"></i>
                                        <strong>Nội dung nhạy cảm</strong>
                                        <div class="text-muted small">Hình ảnh hoặc nội dung không phù hợp với cộng đồng</div>
                                    </label>
                                </div>
                                <div class="form-check border rounded p-3">
                                    <input class="form-check-input" type="radio" name="LyDo" id="lydo2" value="NgonNguThoTuc" required>
                                    <label class="form-check-label" for="lydo2">
                                        <i class="bi bi-chat-square-x text-danger me-2"></i>
                                        <strong>Ngôn ngữ thô tục</strong>
                                        <div class="text-muted small">Sử dụng từ ngữ tục tĩu, xúc phạm</div>
                                    </label>
                                </div>
                                <div class="form-check border rounded p-3">
                                    <input class="form-check-input" type="radio" name="LyDo" id="lydo3" value="CongKichThuDich" required>
                                    <label class="form-check-label" for="lydo3">
                                        <i class="bi bi-person-x text-danger me-2"></i>
                                        <strong>Công kích / Thù địch</strong>
                                        <div class="text-muted small">Nội dung kích động, phân biệt đối xử hoặc tấn công cá nhân</div>
                                    </label>
                                </div>
                                <div class="form-check border rounded p-3">
                                    <input class="form-check-input" type="radio" name="LyDo" id="lydo4" value="TinGiaMaoLua" required>
                                    <label class="form-check-label" for="lydo4">
                                        <i class="bi bi-exclamation-triangle text-dark me-2"></i>
                                        <strong>Tin giả / Lừa đảo</strong>
                                        <div class="text-muted small">Thông tin sai lệch, gây hiểu nhầm hoặc có dấu hiệu lừa đảo</div>
                                    </label>
                                </div>
                                <div class="form-check border rounded p-3">
                                    <input class="form-check-input" type="radio" name="LyDo" id="lydo5" value="Khac" required>
                                    <label class="form-check-label" for="lydo5">
                                        <i class="bi bi-three-dots text-secondary me-2"></i>
                                        <strong>Lý do khác</strong>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="mb-1">
                            <label class="form-label fw-semibold">Mô tả thêm <span class="text-muted fw-normal">(tùy chọn)</span></label>
                            <textarea name="MoTa" class="form-control" rows="3"
                                      placeholder="Mô tả rõ hơn về nội dung vi phạm..."
                                      maxlength="500"></textarea>
                            <div class="form-text text-end" id="demKyTu">0 / 500</div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-flag me-1"></i>Gửi báo cáo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <% } %>

    <%- include('javascript')%>
    <script>
        // Xử lý modal báo cáo
        (function () {
            const modal = document.getElementById('modalBaoCao');
            if (!modal) return;

            modal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                const loai = btn.getAttribute('data-loai');
                const id = btn.getAttribute('data-id');

                document.getElementById('baocaoLoai').value = loai;
                document.getElementById('baocaoId').value = id;
                document.getElementById('baocaoRedirect').value = window.location.pathname + window.location.search;

                const moTa = document.getElementById('baocaoMoTaDoiTuong');
                moTa.textContent = loai === 'BaiViet'
                    ? 'Bạn đang báo cáo bài viết này. Vui lòng chọn lý do vi phạm.'
                    : 'Bạn đang báo cáo bình luận này. Vui lòng chọn lý do vi phạm.';

                // Reset form
                document.getElementById('formBaoCao').reset();
                document.getElementById('demKyTu').textContent = '0 / 500';
            });

            // Đếm ký tự textarea
            const textarea = document.querySelector('#formBaoCao textarea[name="MoTa"]');
            const demKyTu = document.getElementById('demKyTu');
            if (textarea && demKyTu) {
                textarea.addEventListener('input', function () {
                    demKyTu.textContent = this.value.length + ' / 500';
                });
            }
        })();
    </script>
    <script>
        (function () {
            const container = document.querySelector('.smart-sidebar-container');
            const sidebar = document.querySelector('.detail-sidebar-sticky');
            const footer = document.querySelector('footer') || document.querySelector('.footer') || document.querySelector('body > .container > div:last-child');
            const headerOffset = 84;
            const viewportGap = 16;
            const breakpoint = Number((container && container.dataset.stickyBreakpoint) || 992);
            let lastScrollY = window.scrollY;

            if (!container || !sidebar) return;

            const resetSidebarStyle = () => {
                sidebar.style.position = '';
                sidebar.style.top = '';
                sidebar.style.left = '';
                sidebar.style.right = '';
            };

            const updateSmartSticky = () => {
                if (window.innerWidth < breakpoint) {
                    resetSidebarStyle();
                    return;
                }

                const currentScrollY = window.scrollY;
                const isScrollingDown = currentScrollY > lastScrollY;
                lastScrollY = currentScrollY;

                const containerRect = container.getBoundingClientRect();
                const containerTop = currentScrollY + containerRect.top;
                const containerHeight = container.offsetHeight;
                const sidebarHeight = sidebar.offsetHeight;
                const footerTop = footer
                    ? currentScrollY + footer.getBoundingClientRect().top
                    : Number.POSITIVE_INFINITY;

                const minTop = containerTop;
                const maxTop = Math.min(containerTop + containerHeight, footerTop - viewportGap) - sidebarHeight;

                const desiredTop = isScrollingDown
                    ? currentScrollY + window.innerHeight - sidebarHeight - viewportGap
                    : currentScrollY + headerOffset;

                const clampedTop = Math.max(minTop, Math.min(desiredTop, maxTop));

                sidebar.style.position = 'absolute';
                sidebar.style.top = `${Math.max(0, clampedTop - containerTop)}px`;
                sidebar.style.left = '0';
                sidebar.style.right = '0';
            };

            window.addEventListener('scroll', updateSmartSticky, { passive: true });
            window.addEventListener('resize', updateSmartSticky);
            updateSmartSticky();
        })();
    </script>
</body>

</html>