<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang tin điện tử
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('navbar') %>

        <!-- Nội dung chính -->
        <div class="card mt-3">
            <div class="card-header">
                <%= title %>
            </div>
            <div class="card-body">
                <% if (baiviet) { %>
                    <div class="mb-3">
                        <h4><%= baiviet.TieuDe %></h4>
                        <p class="text-muted">
                            Chủ đề: <%= baiviet.ChuDe ? baiviet.ChuDe.TenChuDe : 'N/A' %> | 
                            Tác giả: <%= baiviet.TaiKhoan ? baiviet.TaiKhoan.TenDangNhap : 'N/A' %> | 
                            Ngày đăng: <%= new Date(baiviet.NgayDang).toLocaleDateString('vi-VN') %> | 
                            Lượt xem: <%= baiviet.LuotXem %>
                        </p>
                        <p><strong>Tóm tắt:</strong> <%= baiviet.TomTat %></p>
                        <div><strong>Nội dung:</strong></div>
                        <div><%- baiviet.NoiDung %></div>
                    </div>
                <% } else { %>
                    <p>Bài viết không tồn tại.</p>
                <% } %>
            </div>
        </div>

        <!-- Footer -->
        <%- include('footer') %>
    </div>

    <!-- Java Script -->
    <%- include('javascript')%>
</body>

</html>