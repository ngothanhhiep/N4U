<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    (function () {
        'use strict';

        // 1. Xử lý Validation chung của Bootstrap
        const forms = document.querySelectorAll('.needs-validation');
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                // Kiểm tra logic mật khẩu khớp nhau (dành riêng cho trang Đăng ký)
                const password = document.getElementById('MatKhau');
                const confirmPassword = document.getElementById('XacNhanMatKhau');
                
                if (password && confirmPassword) {
                    if (password.value !== confirmPassword.value) {
                        confirmPassword.setCustomValidity("Mật khẩu không khớp");
                    } else {
                        confirmPassword.setCustomValidity("");
                    }
                }

                // Kiểm tra toàn bộ form
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });

        // 2. Xử lý Ẩn/Hiện mật khẩu (Dành cho trang Đăng nhập)
        const toggleBtn = document.querySelector('#togglePassword');
        const passInput = document.querySelector('#passwordInput');
        if (toggleBtn && passInput) {
            toggleBtn.addEventListener('click', function () {
                const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passInput.setAttribute('type', type);
                // Đổi icon
                this.classList.toggle('bi-eye');
                this.classList.toggle('bi-eye-slash');
            });
        }

        // 3. Xử lý xem trước ảnh (Dành cho trang Đăng ký/Profile)
        const hinhAnhInput = document.querySelector('#HinhAnh');
        if (hinhAnhInput) {
            hinhAnhInput.addEventListener('change', function(event) {
                const reader = new FileReader();
                reader.onload = function () {
                    const output = document.getElementById('imgPreview');
                    if (output) output.src = reader.result;
                };
                if (event.target.files[0]) {
                    reader.readAsDataURL(event.target.files[0]);
                }
            });
        }
    })();
</script>