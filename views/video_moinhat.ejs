<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
    <style>
        .video-card {
            transition: transform 0.2s, box-shadow 0.2s;
            border: none;
            cursor: pointer;
        }

        .video-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1) !important;
        }

        .video-thumb {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #000;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container bg-white shadow-sm px-0">
        <%- include('navbar') %>

        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                <h4 class="fw-bold border-start border-danger border-4 ps-2 text-uppercase mb-0">
                    <i class="bi bi-play-btn text-danger me-2"></i>Video mới nhất
                </h4>
                <span class="text-muted small">
                    Tổng: <%= totalItems || 0 %> video &bull; Trang <%= currentPage || 1 %>/<%= totalPages || 1 %>
                </span>
            </div>

            <% if (video && video.length > 0) { %>
                <div class="row g-4">
                    <% video.forEach(item => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card video-card shadow-sm h-100" data-href="/video/xem/<%= item._id %>">
                                <div class="ratio ratio-16x9">
                                    <% if (isYoutubeEmbedUrl(item.VideoURL)) { %>
                                        <iframe src="<%- item.VideoURL %>" title="<%= item.TenVideo %>" allowfullscreen style="border:0;"></iframe>
                                    <% } else { %>
                                        <video class="video-thumb" controls preload="metadata">
                                            <source src="<%- item.VideoURL %>">
                                            Trình duyệt không hỗ trợ phát video.
                                        </video>
                                    <% } %>
                                </div>

                                <div class="card-body d-flex flex-column">
                                    <h6 class="fw-bold mb-2">
                                        <a href="/video/xem/<%= item._id %>" class="text-decoration-none text-dark stretched-link"><%= item.TenVideo %></a>
                                    </h6>
                                    <div class="small text-muted mb-2">
                                        <i class="bi bi-person-circle me-1"></i>
                                        <%= item.TaiKhoan ? (item.TaiKhoan.HoVaTen || item.TaiKhoan.TenDangNhap || item.TaiKhoan.Email) : 'Ẩn danh' %>
                                    </div>
                                    <div class="small text-muted mb-3">
                                        <i class="bi bi-calendar3 me-1"></i><%= new Date(item.createdAt).toLocaleString('vi-VN') %>
                                    </div>
                                    <% if (item.BaiViet) { %>
                                        <a href="/baiviet/<%= item.BaiViet._id %>" class="small text-decoration-none mt-auto">
                                            <i class="bi bi-link-45deg"></i> Xem bài viết liên quan
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>

                <% if ((totalPages || 1) > 1) { %>
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="/video/moinhat?page=<%= currentPage - 1 %>">
                                    <i class="bi bi-chevron-left"></i> Trước
                                </a>
                            </li>
                            <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                    <a class="page-link" href="/video/moinhat?page=<%= i %>"><%= i %></a>
                                </li>
                            <% } %>
                            <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                <a class="page-link" href="/video/moinhat?page=<%= currentPage + 1 %>">
                                    Sau <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                <% } %>
            <% } else { %>
                <div class="alert alert-light text-center py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>
                    <p class="text-muted">Chưa có video nào.</p>
                </div>
            <% } %>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript')%>
    <script>
        document.querySelectorAll('.video-card').forEach(function (card) {
            card.addEventListener('click', function (event) {
                if (event.target.closest('a, button, iframe, video, .page-link')) return;

                var href = card.getAttribute('data-href');
                if (href) {
                    window.location.href = href;
                }
            });
        });
    </script>
</body>

</html>
