<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Quản trị</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-plus-circle-fill"></i> <%= title %>
            </div>
            <div class="card-body">
                <form action="/quangcao/them" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="TenQuangCao" class="form-label">Tên quảng cáo</label>
                        <input type="text" class="form-control" id="TenQuangCao" name="TenQuangCao"
                               placeholder="Ví dụ: Banner khuyến mãi tháng 4" required />
                        <div class="invalid-feedback">Vui lòng nhập tên quảng cáo.</div>
                    </div>

                    <div class="mb-3">
                        <label for="HinhAnh" class="form-label">Hình ảnh (có thể để trống)</label>
                        <input type="url" class="form-control" id="HinhAnh" name="HinhAnh"
                               placeholder="https://example.com/banner.jpg" />
                        <div class="form-text">Nhập link ảnh hoặc upload file ở bên dưới.</div>
                    </div>

                    <div class="mb-3">
                        <label for="HinhAnhFile" class="form-label">Upload ảnh từ máy (tùy chọn)</label>
                        <input type="file" class="form-control" id="HinhAnhFile" name="HinhAnhFile" accept="image/*" />
                        <div class="form-text">Nếu chọn cả link và file, hệ thống sẽ ưu tiên file upload.</div>
                    </div>

                    <div class="mb-3">
                        <label for="LinkQuangCao" class="form-label">Link quảng cáo (có thể để trống)</label>
                        <input type="url" class="form-control" id="LinkQuangCao" name="LinkQuangCao"
                               placeholder="https://example.com" />
                    </div>

                    <hr>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Thêm mới
                    </button>
                    <a href="/quangcao" class="btn btn-secondary">Quay lại</a>
                </form>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript') %>
</body>

</html>
