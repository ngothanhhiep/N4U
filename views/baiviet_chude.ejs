<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang tin điện tử
    </title>
    <style>
        .article-thumb-fixed { width: 100%; height: 220px; object-fit: cover; }

        @media (min-width: 768px) {
            .smart-sidebar-container {
                position: relative;
            }

            .category-sidebar-sticky {
                position: relative;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('navbar') %>

        <!-- Nội dung chính -->
        <div class="card mt-3">
            <div class="card-header">
                <%= title %>
            </div>
            <div class="card-body">
                <% if (chude) { %>
                    <div class="alert alert-info">
                        <h5>Chủ đề: <%= chude.TenChuDe %></h5>
                    </div>
                <% } %>
                <div class="row">
                    <div class="col-md-8">
                        <h4>Bài viết trong chủ đề</h4>
                        <% if (baiviet && baiviet.length > 0) { %>
                            <% baiviet.forEach(bv => { %>
                                <div class="card mb-3">
                                    <img src="<%- bv.displayImage || '/images/noimage.png' %>" alt="<%= bv.TieuDe %>" class="card-img-top article-thumb-fixed" onerror="this.src='/images/noimage.png'">
                                    <div class="card-body">
                                        <h5 class="card-title"><a href="/baiviet/<%= bv._id %>" class="text-decoration-none"><%= bv.TieuDe %></a></h5>
                                        <p class="card-text"><%= bv.TomTat %></p>
                                        <p class="card-text"><small class="text-muted">
                                            Chủ đề: <%= bv.ChuDe ? bv.ChuDe.TenChuDe : 'N/A' %> | 
                                            Tác giả: <%= bv.TaiKhoan ? bv.TaiKhoan.TenDangNhap : 'N/A' %> | 
                                            Ngày đăng: <%= new Date(bv.NgayDang).toLocaleDateString('vi-VN') %> | 
                                            Lượt xem: <%= bv.LuotXem %>
                                        </small></p>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>Không có bài viết nào trong chủ đề này.</p>
                        <% } %>
                    </div>
                    <div class="col-md-4 smart-sidebar-container" data-sticky-breakpoint="768">
                        <div class="category-sidebar-sticky">
                        <h4>Chủ đề</h4>
                        <div class="mb-4">
                            <% if (chuyenmuc && chuyenmuc.length > 0) { %>
                                <% chuyenmuc.forEach(cm => { %>
                                    <a href="/chude/<%= cm._id %>" class="badge bg-primary text-decoration-none me-2 mb-2"><%= cm.TenChuDe %></a>
                                <% }); %>
                            <% } else { %>
                                <p>Không có chủ đề nào.</p>
                            <% } %>
                        </div>
                        <h4>Bài viết xem nhiều</h4>
                        <% if (xemnhieu && xemnhieu.length > 0) { %>
                            <% xemnhieu.forEach(xn => { %>
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <h6 class="card-title"><a href="/baiviet/<%= xn._id %>" class="text-decoration-none"><%= xn.TieuDe %></a></h6>
                                        <p class="card-text"><small class="text-muted">Lượt xem: <%= xn.LuotXem %></small></p>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>Không có bài viết nào.</p>
                        <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <%- include('footer') %>
    </div>

    <!-- Java Script -->
    <%- include('javascript')%>
    <script>
        (function () {
            const container = document.querySelector('.smart-sidebar-container');
            const sidebar = document.querySelector('.category-sidebar-sticky');
            const footer = document.querySelector('footer') || document.querySelector('.footer') || document.querySelector('body > .container > div:last-child');
            const headerOffset = 84;
            const viewportGap = 16;
            const breakpoint = Number((container && container.dataset.stickyBreakpoint) || 768);
            let lastScrollY = window.scrollY;

            if (!container || !sidebar) return;

            const resetSidebarStyle = () => {
                sidebar.style.position = '';
                sidebar.style.top = '';
                sidebar.style.left = '';
                sidebar.style.right = '';
            };

            const updateSmartSticky = () => {
                if (window.innerWidth < breakpoint) {
                    resetSidebarStyle();
                    return;
                }

                const currentScrollY = window.scrollY;
                const isScrollingDown = currentScrollY > lastScrollY;
                lastScrollY = currentScrollY;
                const containerRect = container.getBoundingClientRect();
                const containerTop = currentScrollY + containerRect.top;
                const containerHeight = container.offsetHeight;
                const sidebarHeight = sidebar.offsetHeight;
                const footerTop = footer
                    ? currentScrollY + footer.getBoundingClientRect().top
                    : Number.POSITIVE_INFINITY;

                const minTop = containerTop;
                const maxTop = Math.min(containerTop + containerHeight, footerTop - viewportGap) - sidebarHeight;
                const desiredTop = isScrollingDown
                    ? currentScrollY + window.innerHeight - sidebarHeight - viewportGap
                    : currentScrollY + headerOffset;
                const clampedTop = Math.max(minTop, Math.min(desiredTop, maxTop));

                sidebar.style.position = 'absolute';
                sidebar.style.top = `${Math.max(0, clampedTop - containerTop)}px`;
                sidebar.style.left = '0';
                sidebar.style.right = '0';
            };

            window.addEventListener('scroll', updateSmartSticky, { passive: true });
            window.addEventListener('resize', updateSmartSticky);
            updateSmartSticky();
        })();
    </script>
</body>

</html>