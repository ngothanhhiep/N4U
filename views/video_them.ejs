<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-camera-video"></i>
                <%= title %>
            </div>
            <form action="/video/them" method="post" class="needs-validation" novalidate enctype="multipart/form-data">
                <div class="row p-3">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label for="TenVideo" class="form-label fw-bold">Tên video</label>
                            <input type="text" class="form-control" id="TenVideo" name="TenVideo" required />
                        </div>

                        <div class="mb-3">
                            <label for="BaiViet" class="form-label fw-bold">Bài viết liên kết (tùy chọn)</label>
                            <select class="form-select" id="BaiViet" name="BaiViet">
                                <option value="">-- Không liên kết bài viết --</option>
                                <% baiviet.forEach(item => { %>
                                    <option value="<%= item._id %>"><%= item.TieuDe %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="Video" class="form-label fw-bold">File video</label>
                            <input type="file" class="form-control" id="Video" name="Video"
                                accept="video/mp4,video/webm,video/quicktime,video/x-msvideo,video/x-matroska" />
                            <div class="form-text">Hỗ trợ: mp4, webm, mov, avi, mkv. Dung lượng tối đa 100MB.</div>
                        </div>

                        <div class="mb-3">
                            <label for="VideoLink" class="form-label fw-bold">Hoặc dán link video</label>
                            <input type="url" class="form-control" id="VideoLink" name="VideoLink"
                                placeholder="Ví dụ: https://www.youtube.com/watch?v=... hoặc link .mp4" />
                            <div class="form-text">Bạn có thể upload file hoặc nhập link video. Nếu nhập cả hai, hệ thống sẽ ưu tiên file upload.</div>
                        </div>
                    </div>

                    <div class="col-md-4 text-center border-start">
                        <label class="form-label fw-bold d-block">Xem trước</label>
                        <div class="ratio ratio-16x9 rounded border overflow-hidden" style="background: #000;">
                            <video id="videoPreview" class="w-100 h-100" controls>
                                <source id="videoSource" src="" type="video/mp4">
                                Trình duyệt không hỗ trợ phát video.
                            </video>
                            <iframe id="youtubePreview" src="" title="YouTube preview" allowfullscreen style="border:0; display:none;"></iframe>
                        </div>
                        <div class="small text-muted mt-2">Video sẽ được upload lên Cloudinary sau khi bấm Lưu.</div>
                    </div>
                </div>

                <div class="px-3 pb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-cloud-arrow-up"></i> Đăng video
                    </button>
                </div>
            </form>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript')%>
    <script>
        var fileInput = document.getElementById('Video');
        var linkInput = document.getElementById('VideoLink');
        var videoPreview = document.getElementById('videoPreview');
        var videoSource = document.getElementById('videoSource');
        var youtubePreview = document.getElementById('youtubePreview');

        function toYoutubeEmbed(url) {
            try {
                var parsed = new URL(url);
                var host = parsed.hostname.toLowerCase();

                if (host.indexOf('youtu.be') !== -1) {
                    var idFromShort = parsed.pathname.replace('/', '').split('/')[0];
                    return idFromShort ? 'https://www.youtube.com/embed/' + idFromShort : '';
                }

                if (host.indexOf('youtube.com') !== -1) {
                    if (parsed.pathname.indexOf('/embed/') === 0) {
                        var idFromEmbed = parsed.pathname.split('/embed/')[1].split('/')[0];
                        return idFromEmbed ? 'https://www.youtube.com/embed/' + idFromEmbed : '';
                    }

                    var id = parsed.searchParams.get('v');
                    return id ? 'https://www.youtube.com/embed/' + id : '';
                }
            } catch (error) {
                return '';
            }

            return '';
        }

        function showVideoTag(url) {
            youtubePreview.style.display = 'none';
            youtubePreview.src = '';
            videoPreview.style.display = 'block';
            videoSource.src = url;
            videoPreview.load();
        }

        function showYoutubeIframe(embedUrl) {
            videoPreview.pause();
            videoPreview.style.display = 'none';
            videoSource.src = '';
            youtubePreview.style.display = 'block';
            youtubePreview.src = embedUrl;
        }

        function renderPreviewFromLink(link) {
            var youtubeEmbed = toYoutubeEmbed(link);
            if (youtubeEmbed) {
                showYoutubeIframe(youtubeEmbed);
            } else {
                showVideoTag(link);
            }
        }

        fileInput.addEventListener('change', function (event) {
            var file = event.target.files && event.target.files[0];
            if (!file) return;

            showVideoTag(URL.createObjectURL(file));
        });

        linkInput.addEventListener('change', function () {
            var link = (linkInput.value || '').trim();
            if (!link) return;

            renderPreviewFromLink(link);
        });

        (function () {
            'use strict';
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        var hasFile = fileInput.files && fileInput.files.length > 0;
                        var hasLink = (linkInput.value || '').trim().length > 0;

                        if (!hasFile && !hasLink) {
                            event.preventDefault();
                            event.stopPropagation();
                            linkInput.setCustomValidity('Vui lòng chọn file video hoặc nhập link video.');
                        } else {
                            linkInput.setCustomValidity('');
                        }

                        if (!form.checkValidity()) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
        })();
    </script>
</body>

</html>
