<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Quản trị</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase d-flex align-items-center justify-content-between flex-wrap gap-2">
                <span><i class="bi bi-chat-dots"></i> <%= title %></span>
                <form action="/binhluan" method="GET" class="d-flex gap-2" style="min-width:280px">
                    <input type="text"
                           name="tukhoa"
                           class="form-control form-control-sm"
                           placeholder="Tìm theo nội dung bình luận..."
                           value="<%= typeof tukhoa !== 'undefined' ? tukhoa : '' %>">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-search"></i>
                    </button>
                    <% if (typeof tukhoa !== 'undefined' && tukhoa) { %>
                        <a href="/binhluan" class="btn btn-outline-secondary btn-sm" title="Xóa bộ lọc">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    <% } %>
                </form>
            </div>
            <div class="card-body table-responsive">
                <% if (typeof tukhoa !== 'undefined' && tukhoa) { %>
                    <div class="alert alert-info py-2 mb-3 small">
                        <i class="bi bi-search me-1"></i>Kết quả tìm kiếm cho: <strong>"<%= tukhoa %>"</strong> — <%= totalItems || 0 %> bình luận
                    </div>
                <% } %>
                <table class="table table-bordered table-hover table-sm mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th width="5%">#</th>
                            <th width="15%">Người bình luận</th>
                            <th width="20%">Bài viết</th>
                            <th width="25%">Nội dung</th>
                            <th width="10%">Tương tác</th>
                            <th width="13%">Ngày tạo</th>
                            <th width="12%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt = ((currentPage || 1) - 1) * (pageSize || 20) + 1; %>
                        <% if (binhluan && binhluan.length > 0) { %>
                            <% binhluan.forEach(item => { %>
                                <tr>
                                    <td class="align-middle text-center"><%= stt++ %></td>
                                    <td class="align-middle">
                                        <%= item.TaiKhoan ? (item.TaiKhoan.HoVaTen || item.TaiKhoan.TenDangNhap) : 'N/A' %>
                                    </td>
                                    <td class="align-middle">
                                        <% if (item.BaiViet) { %>
                                            <a href="/baiviet/<%= item.BaiViet._id %>" class="text-decoration-none">
                                                <%= item.BaiViet.TieuDe %>
                                            </a>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </td>
                                    <td class="align-middle"><%= item.NoiDung %></td>
                                    <td class="align-middle text-center">
                                        <span class="text-primary"><i class="bi bi-hand-thumbs-up"></i> <%= item.LuotThich.length %></span>
                                        <br>
                                        <span class="text-danger"><i class="bi bi-hand-thumbs-down"></i> <%= item.LuotKhongThich.length %></span>
                                    </td>
                                    <td class="align-middle text-center small">
                                        <%= new Date(item.createdAt).toLocaleString('vi-VN') %>
                                    </td>
                                    <td class="align-middle text-center">
                                        <% if (session.QuyenHan === 'admin' || session.QuyenHan === 'maneger' || session.MaNguoiDung == item.TaiKhoan._id) { %>
                                            <a href="/binhluan/xoa/<%= item._id %>" class="btn btn-sm btn-danger" onclick="return confirm('Bạn chắc chắn muốn xóa bình luận này?');" title="Xóa">
                                                <i class="bi bi-trash3"></i> Xóa
                                            </a>
                                        <% } else { %>
                                            <span class="text-muted small">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center text-muted">Chưa có bình luận nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                    <div class="text-muted small">
                        Tổng: <%= totalItems || 0 %> bình luận • Trang <%= currentPage || 1 %>/<%= totalPages || 1 %>
                    </div>

                    <% if ((totalPages || 1) > 1) { %>
                        <% const q = (typeof tukhoa !== 'undefined' && tukhoa) ? '&tukhoa=' + encodeURIComponent(tukhoa) : ''; %>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= currentPage - 1 %><%= q %>">Trước</a>
                                </li>
                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %><%= q %>"><%= i %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= currentPage + 1 %><%= q %>">Sau</a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript')%>
</body>

</html>