<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Quản trị</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-list-stars"></i> <%= title %>
            </div>
            <div class="card-body table-responsive">
                <a href="/baiviet/them" class="btn btn-primary mb-3">
                    <i class="bi bi-plus-lg"></i> Đăng bài viết mới
                </a>

                <table class="table table-bordered table-hover table-sm mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th width="5%">#</th>
                            <th width="10%">Ảnh</th>
                            <th width="15%">Người đăng</th>
                            <th width="10%">Chủ đề</th>
                            <th width="30%">Tiêu đề</th>
                            <th width="15%">Ngày đăng</th>
                            <th width="5%" title="Tình trạng kiểm duyệt">Duyệt</th>
                            <th width="5%">Sửa</th>
                            <th width="5%">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt = ((currentPage || 1) - 1) * (pageSize || 20) + 1; %>
                        <% baiviet.forEach(bv => { %>
                            <tr>
                                <td class="align-middle text-center"><%= stt++ %></td>
                                <td class="align-middle text-center">
                                    <img src="<%= bv.HinhAnh %>" width="80" class="img-thumbnail" alt="Thumb">
                                </td>
                                <td class="align-middle small">
                                    <i class="bi bi-person"></i> <%= bv.TaiKhoan ? bv.TaiKhoan.HoVaTen : 'N/A' %>
                                </td>
                                <td class="align-middle small text-center">
                                    <span class="badge bg-info text-dark">
                                        <%= bv.ChuDe ? bv.ChuDe.TenChuDe : 'N/A' %>
                                    </span>
                                </td>
                                <td class="align-middle">
                                    <a href="/baiviet/<%= bv._id %>" class="text-decoration-none fw-bold">
                                        <%= bv.TieuDe %>
                                    </a>
                                    <br>
                                    <small class="text-muted"><i class="bi bi-eye"></i> <%= bv.LuotXem %></small>
                                </td>
                                <td class="align-middle small text-center">
                                    <%= new Date(bv.NgayDang).toLocaleString("vi-VN") %>
                                </td>
                                <td class="align-middle text-center">
                                    <a href="/baiviet/duyet/<%= bv._id %>">
                                        <% if(bv.KiemDuyet == 1) { %>
                                            <i class="bi bi-check-circle-fill text-success" title="Đã duyệt"></i>
                                        <% } else { %>
                                            <i class="bi bi-x-circle-fill text-danger" title="Chưa duyệt"></i>
                                        <% } %>
                                    </a>
                                </td>
                                <td class="align-middle text-center">
                                    <a href="/baiviet/sua/<%= bv._id %>" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                </td>
                                <td class="align-middle text-center">
                                    <a href="/baiviet/xoa/<%= bv._id %>" 
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Bạn có thực sự muốn xóa bài viết: <%= bv.TieuDe %>?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                        
                        <% if(baiviet.length == 0) { %>
                            <tr>
                                <td colspan="9" class="text-center text-muted">Không có bài viết nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                    <div class="text-muted small">
                        Tổng: <%= totalItems || 0 %> bài viết • Trang <%= currentPage || 1 %>/<%= totalPages || 1 %>
                    </div>

                    <% if ((totalPages || 1) > 1) { %>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                                </li>
                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript')%>
</body>

</html>