<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
    <style>
        .profile-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 180px;
            border-radius: 15px 15px 0 0;
        }
        .profile-img {
            width: 130px;
            height: 130px;
            object-fit: cover;
            border: 4px solid #fff;
            border-radius: 50%;
            margin-top: -65px;
            background-color: #fff;
        }
        .stat-card {
            border: none;
            border-radius: 12px;
            transition: transform 0.2s;
        }
        .stat-card:hover { transform: translateY(-5px); }
        .nav-tabs { border-bottom: 2px solid #dee2e6; }
        .nav-link { color: #6c757d; font-weight: 600; border: none !important; }
        .nav-link.active { color: #4e73df !important; border-bottom: 3px solid #4e73df !important; background: none !important; }
        .article-item { transition: background 0.2s; border-left: 4px solid transparent; }
        .article-item:hover { background: #f8f9fc; border-left: 4px solid #4e73df; }
    </style>
</head>

<body class="bg-light">
    <div class="container py-4">
        <%- include('navbar') %>

        <div class="row mt-4">
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="profile-header"></div>
                    <div class="card-body text-center pt-0">
                        <img src="<%= taikhoan.HinhAnh ? taikhoan.HinhAnh : '/images/default-avatar.png' %>" class="profile-img shadow mb-3">
                        <h4 class="fw-bold mb-1"><%= taikhoan.HoVaTen %></h4>
                        <p class="text-muted small mb-3">@<%= taikhoan.TenDangNhap %></p>
                        
                        <div class="mb-3">
                            <span class="badge <%= taikhoan.QuyenHan == 'admin' ? 'bg-danger' : 'bg-primary' %> rounded-pill">
                                <%= taikhoan.QuyenHan == 'admin' ? 'Quản trị viên' : 'Thành viên' %>
                            </span>
                            <span class="badge bg-success rounded-pill">Đang hoạt động</span>
                        </div>

                        <div class="text-start mt-4 small">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                                <span class="fw-medium"><%= taikhoan.Email %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted"><i class="bi bi-calendar3 me-2"></i>Tham gia</span>
                                <span class="fw-medium"><%= new Date(taikhoan.createdAt).toLocaleDateString("vi-VN") %></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <% if (session && (session.MaNguoiDung == taikhoan._id || session.QuyenHan == 'admin')) { %>
                                <a href="/taikhoan/sua/<%= taikhoan._id %>" class="btn btn-primary btn-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa hồ sơ
                                </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="row g-3 mb-4">
                    <div class="col-3">
                        <div class="card stat-card shadow-sm bg-white p-3 text-center">
                            <h4 class="fw-bold text-primary mb-0"><%= thongke.soBaiViet %></h4>
                            <small class="text-muted">Bài viết</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="card stat-card shadow-sm bg-white p-3 text-center">
                            <h4 class="fw-bold text-danger mb-0"><%= thongke.soVideo || 0 %></h4>
                            <small class="text-muted">Video</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="card stat-card shadow-sm bg-white p-3 text-center">
                            <h4 class="fw-bold text-success mb-0"><%= thongke.tongLuotXem %></h4>
                            <small class="text-muted">Lượt xem</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="card stat-card shadow-sm bg-white p-3 text-center">
                            <h4 class="fw-bold text-info mb-0"><%= thongke.tongBinhLuan %></h4>
                            <small class="text-muted">Bình luận</small>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header bg-white pt-3">
                        <ul class="nav nav-tabs card-header-tabs" id="profileTabs" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="articles-tab" data-bs-toggle="tab" href="#articles" role="tab">
                                    <i class="bi bi-journal-text me-1"></i> 
                                    <%= (session && session.MaNguoiDung == taikhoan._id) ? 'Bài viết của tôi' : 'Bài viết của ' + taikhoan.HoVaTen %>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="videos-tab" data-bs-toggle="tab" href="#videos" role="tab">
                                    <i class="bi bi-collection-play me-1"></i>
                                    <%= (session && session.MaNguoiDung == taikhoan._id) ? 'Video của tôi' : 'Video của ' + taikhoan.HoVaTen %>
                                </a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-0">
                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="articles" role="tablist">
                                <div class="list-group list-group-flush">
                                    <% if(baiviet.length > 0) { %>
                                        <% baiviet.forEach(bv => { %>
                                            <div class="list-group-item article-item p-3">
                                                <div class="d-flex gap-3 align-items-center">
                                                    <img src="<%- bv.displayImage || bv.HinhAnh || '/images/noimage.png' %>"
                                                         alt="<%= bv.TieuDe %>"
                                                         onerror="this.src='/images/noimage.png'"
                                                         class="rounded flex-shrink-0"
                                                         style="width: 72px; height: 72px; object-fit: cover;">
                                                    <div class="flex-grow-1 min-width-0">
                                                        <h6 class="mb-1">
                                                            <a href="/baiviet/<%= bv._id %>" class="text-decoration-none text-dark fw-bold">
                                                                <%= bv.TieuDe %>
                                                            </a>
                                                        </h6>
                                                        <small class="text-muted">
                                                            <i class="bi bi-clock me-1"></i><%= new Date(bv.NgayDang).toLocaleDateString('vi-VN') %>
                                                        </small>
                                                    </div>
                                                    <div class="text-end flex-shrink-0">
                                                        <span class="badge bg-light text-dark border me-1">
                                                            <i class="bi bi-eye me-1"></i><%= bv.LuotXem %>
                                                        </span>
                                                        <span class="badge bg-light text-dark border">
                                                            <i class="bi bi-chat me-1"></i><%= bv.SoBinhLuan %>
                                                        </span>
                                                        <% if (session && (session.MaNguoiDung == taikhoan._id || session.QuyenHan == 'admin')) { %>
                                                            <a href="/baiviet/sua/<%= bv._id %>" class="btn btn-sm btn-outline-primary ms-2" title="Sửa">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </a>
                                                            <a href="/baiviet/xoa/<%= bv._id %>" class="btn btn-sm btn-outline-danger ms-1" title="Xóa"
                                                               onclick="return confirm('Bạn có chắc muốn xóa bài viết này?')">
                                                                <i class="bi bi-trash"></i>
                                                            </a>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="p-5 text-center text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            Chưa có bài viết nào được đăng.
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="videos" role="tabpanel" aria-labelledby="videos-tab">
                                <div class="list-group list-group-flush">
                                    <% if(video && video.length > 0) { %>
                                        <% video.forEach(v => { %>
                                            <div class="list-group-item article-item p-3">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-1">
                                                            <a href="/video/xem/<%= v._id %>" class="text-decoration-none text-dark fw-bold">
                                                                <%= v.TenVideo %>
                                                            </a>
                                                        </h6>
                                                        <small class="text-muted d-block">
                                                            <i class="bi bi-clock me-1"></i><%= new Date(v.createdAt).toLocaleDateString('vi-VN') %>
                                                        </small>
                                                        <% if (v.BaiViet) { %>
                                                            <small class="text-muted d-block">
                                                                <i class="bi bi-link-45deg me-1"></i>Bài viết: <%= v.BaiViet.TieuDe %>
                                                            </small>
                                                        <% } %>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="badge bg-light text-dark border">
                                                            <i class="bi bi-camera-reels me-1"></i><%= v.DinhDang || 'video' %>
                                                        </span>
                                                        <% if (session && (session.MaNguoiDung == taikhoan._id || session.QuyenHan == 'admin')) { %>
                                                            <a href="/video/sua/<%= v._id %>" class="btn btn-sm btn-outline-primary ms-2" title="Sửa">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </a>
                                                            <a href="/video/xoa/<%= v._id %>" class="btn btn-sm btn-outline-danger ms-1" title="Xóa"
                                                               onclick="return confirm('Bạn có chắc muốn xóa video này?')">
                                                                <i class="bi bi-trash"></i>
                                                            </a>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="p-5 text-center text-muted">
                                            <i class="bi bi-camera-video-off fs-1 d-block mb-2"></i>
                                            Chưa có video nào được đăng.
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript') %>
</body>

</html>