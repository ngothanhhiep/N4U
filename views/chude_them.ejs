<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Quản trị</title>
</head>
<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-plus-circle-fill"></i> <%= title %>
            </div>
            <div class="card-body">
                <form action="/chude/them" method="post" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="TenChuDe" class="form-label">Tên chủ đề mới</label>
                        <input type="text" class="form-control" id="TenChuDe" name="TenChuDe" placeholder="Ví dụ: Công nghệ, Đời sống..." required />
                        <div class="invalid-feedback">Vui lòng nhập tên chủ đề.</div>
                    </div>
                    
                    <hr>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Thêm mới
                    </button>
                    <a href="/chude" class="btn btn-secondary">Quay lại</a>
                </form>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript') %>
</body>
</html>