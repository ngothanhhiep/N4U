<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang tin điện tử</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3">
            <div class="card-header fw-bold text-uppercase">
                <i class="bi bi-pencil-square"></i>
                <%= title %>
            </div>
            <div class="card-body">
                <form action="/video/sua/<%= video._id %>" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="TenVideo" class="form-label">Tên video</label>
                        <input type="text" class="form-control" id="TenVideo" name="TenVideo" value="<%= video.TenVideo %>" required />
                    </div>

                    <div class="mb-3">
                        <label for="BaiViet" class="form-label">Bài viết liên kết (tùy chọn)</label>
                        <select class="form-select" id="BaiViet" name="BaiViet">
                            <option value="">-- Không liên kết bài viết --</option>
                            <% baiviet.forEach(item => { %>
                                <option value="<%= item._id %>" <%= video.BaiViet && String(video.BaiViet) === String(item._id) ? 'selected' : '' %>>
                                    <%= item.TieuDe %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Video hiện tại</label>
                        <div class="mb-2">
                            <div class="ratio ratio-16x9 rounded border overflow-hidden" style="background: #000;">
                                <video id="videoPreview" class="w-100 h-100" controls>
                                    <source id="videoSource" src="">
                                    Trình duyệt không hỗ trợ phát video.
                                </video>
                                <iframe id="youtubePreview" src="" title="YouTube preview" allowfullscreen style="border:0; display:none;"></iframe>
                            </div>
                        </div>
                        <input type="file" class="form-control" id="Video" name="Video"
                            accept="video/mp4,video/webm,video/quicktime,video/x-msvideo,video/x-matroska" />
                        <div class="form-text">Nếu chọn file mới, hệ thống sẽ thay video cũ trên Cloudinary.</div>
                    </div>

                    <div class="mb-3">
                        <label for="VideoLink" class="form-label">Hoặc dán link video mới</label>
                        <input type="url" class="form-control" id="VideoLink" name="VideoLink"
                            placeholder="Ví dụ: https://www.youtube.com/watch?v=... hoặc link .mp4" />
                        <div class="form-text">Nếu nhập link mới, hệ thống sẽ chuyển sang dùng link này.</div>
                    </div>

                    <button type="submit" class="btn btn-primary"><i class="bi bi-cloud-arrow-up"></i> Cập nhật video</button>
                    <a href="/video/xem/<%= video._id %>" class="btn btn-outline-secondary">Xem chi tiết</a>
                </form>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript') %>
    <script>
        var fileInput = document.getElementById('Video');
        var linkInput = document.getElementById('VideoLink');
        var videoPreview = document.getElementById('videoPreview');
        var videoSource = document.getElementById('videoSource');
        var youtubePreview = document.getElementById('youtubePreview');
        var currentVideoUrl = '<%- video.VideoURL %>';

        function toYoutubeEmbed(url) {
            try {
                var parsed = new URL(url);
                var host = parsed.hostname.toLowerCase();

                if (host.indexOf('youtu.be') !== -1) {
                    var idFromShort = parsed.pathname.replace('/', '').split('/')[0];
                    return idFromShort ? 'https://www.youtube.com/embed/' + idFromShort : '';
                }

                if (host.indexOf('youtube.com') !== -1) {
                    if (parsed.pathname.indexOf('/embed/') === 0) {
                        var idFromEmbed = parsed.pathname.split('/embed/')[1].split('/')[0];
                        return idFromEmbed ? 'https://www.youtube.com/embed/' + idFromEmbed : '';
                    }

                    var id = parsed.searchParams.get('v');
                    return id ? 'https://www.youtube.com/embed/' + id : '';
                }
            } catch (error) {
                return '';
            }

            return '';
        }

        function showVideoTag(url) {
            youtubePreview.style.display = 'none';
            youtubePreview.src = '';
            videoPreview.style.display = 'block';
            videoSource.src = url;
            videoPreview.load();
        }

        function showYoutubeIframe(embedUrl) {
            videoPreview.pause();
            videoPreview.style.display = 'none';
            videoSource.src = '';
            youtubePreview.style.display = 'block';
            youtubePreview.src = embedUrl;
        }

        function renderPreviewFromLink(link) {
            var youtubeEmbed = toYoutubeEmbed(link);
            if (youtubeEmbed) {
                showYoutubeIframe(youtubeEmbed);
            } else {
                showVideoTag(link);
            }
        }

        fileInput.addEventListener('change', function (event) {
            var file = event.target.files && event.target.files[0];
            if (!file) return;

            showVideoTag(URL.createObjectURL(file));
        });

        linkInput.addEventListener('change', function () {
            var link = (linkInput.value || '').trim();
            if (!link) return;

            renderPreviewFromLink(link);
        });

        if (currentVideoUrl) {
            renderPreviewFromLink(currentVideoUrl);
        }
    </script>
</body>

</html>
