<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title><%= title %> - Quản trị</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

        <div class="card mt-3 mb-3 border-0 shadow-sm">
            <div class="card-header fw-bold text-uppercase bg-white">
                <i class="bi bi-bar-chart-fill text-primary me-2"></i> <%= title %>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-4 col-lg-2">
                        <div class="card h-100 border-0" style="background-color: #fe7c87; color: white;">
                            <div class="card-body">
                                <div class="small">Tài khoản</div>
                                <div class="fs-4 fw-bold"><%= thongke.tongTaiKhoan %></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <div class="card h-100 border-0" style="background-color: #fba09a; color: white;">
                            <div class="card-body">
                                <div class="small">Bài viết</div>
                                <div class="fs-4 fw-bold"><%= thongke.tongBaiViet %></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <div class="card h-100 border-0" style="background-color: #ffcaa7; color: white;">
                            <div class="card-body">
                                <div class="small">Đã duyệt</div>
                                <div class="fs-4 fw-bold"><%= thongke.baiVietDaDuyet %></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <div class="card h-100 border-0" style="background-color: #d6f0ad; color: white;">
                            <div class="card-body">
                                <div class="small">Chờ duyệt</div>
                                <div class="fs-4 fw-bold"><%= thongke.baiVietChoDuyet %></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <div class="card h-100 border-0" style="background-color: #99eacc; color: white;">
                            <div class="card-body">
                                <div class="small">Bình luận</div>
                                <div class="fs-4 fw-bold"><%= thongke.tongBinhLuan %></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <div class="card h-100 border-0" style="background-color: #b2bbe0; color: white;">
                            <div class="card-body">
                                <div class="small">Quảng cáo</div>
                                <div class="fs-4 fw-bold"><%= thongke.tongQuangCao %></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-bar-chart-line-fill text-success me-2"></i>So sánh tháng này với tháng trước
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="p-3 rounded border h-100">
                                    <div class="small text-muted mb-1">Lượt xem bài viết đã duyệt</div>
                                    <div class="fw-bold fs-5 mb-1"><%= soSanhThang.luotXemThangNay.toLocaleString('vi-VN') %></div>
                                    <div class="small">
                                        So với <%= soSanhThang.thangTruocLabel %>:
                                        <span class="fw-bold <%= soSanhThang.phanTramLuotXem >= 0 ? 'text-success' : 'text-danger' %>">
                                            <%= soSanhThang.phanTramLuotXem >= 0 ? '+' : '' %><%= soSanhThang.phanTramLuotXem %>%
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="p-3 rounded border h-100">
                                    <div class="small text-muted mb-1">Số lượng bài viết</div>
                                    <div class="fw-bold fs-5 mb-1"><%= soSanhThang.baiVietThangNay.toLocaleString('vi-VN') %></div>
                                    <div class="small">
                                        So với <%= soSanhThang.thangTruocLabel %>:
                                        <span class="fw-bold <%= soSanhThang.phanTramBaiViet >= 0 ? 'text-success' : 'text-danger' %>">
                                            <%= soSanhThang.phanTramBaiViet >= 0 ? '+' : '' %><%= soSanhThang.phanTramBaiViet %>%
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div style="height: 320px;">
                            <canvas id="monthlyCompareChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-fire text-danger me-2"></i>Top 5 bài viết xem nhiều
                    </div>
                    <div class="card-body table-responsive">
                        <table class="table table-bordered table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th width="5%">#</th>
                                    <th>Tiêu đề</th>
                                    <th width="20%">Tác giả</th>
                                    <th width="15%">Ngày đăng</th>
                                    <th width="12%">Lượt xem</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (topBaiViet && topBaiViet.length > 0) { %>
                                    <% topBaiViet.forEach((item, index) => { %>
                                        <tr>
                                            <td><%= index + 1 %></td>
                                            <td>
                                                <a href="/baiviet/<%= item._id %>" class="text-decoration-none">
                                                    <%= item.TieuDe %>
                                                </a>
                                            </td>
                                            <td><%= item.TaiKhoan ? item.TaiKhoan.HoVaTen : 'N/A' %></td>
                                            <td><%= new Date(item.NgayDang).toLocaleDateString('vi-VN') %></td>
                                            <td><%= item.LuotXem.toLocaleString('vi-VN') %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">Chưa có dữ liệu.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>
    </div>

    <%- include('javascript') %>
    <script>
        (function () {
            const ctx = document.getElementById('monthlyCompareChart');
            if (!ctx) return;

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Lượt xem', 'Bài viết'],
                    datasets: [
                        {
                            label: 'Tháng trước (<%= soSanhThang.thangTruocLabel %>)',
                            data: [<%= soSanhThang.luotXemThangTruoc %>, <%= soSanhThang.baiVietThangTruoc %>],
                            backgroundColor: 'rgba(108, 117, 125, 0.75)',
                            borderColor: 'rgba(108, 117, 125, 1)',
                            borderWidth: 1,
                            borderRadius: 6
                        },
                        {
                            label: 'Tháng này (<%= soSanhThang.thangNayLabel %>)',
                            data: [<%= soSanhThang.luotXemThangNay %>, <%= soSanhThang.baiVietThangNay %>],
                            backgroundColor: 'rgba(25, 135, 84, 0.75)',
                            borderColor: 'rgba(25, 135, 84, 1)',
                            borderWidth: 1,
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top'
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function (value) {
                                    return Number(value).toLocaleString('vi-VN');
                                }
                            }
                        }
                    }
                }
            });
        })();
    </script>
</body>

</html>
