<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang tin điện tử
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('navbar') %>

        <!-- Nội dung chính -->
        <div class="card mt-3">
            <div class="card-header">
                <%= title %>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <h4>Bài viết mới nhất</h4>
                        <% if (baiviet && baiviet.length > 0) { %>
                            <% baiviet.forEach(bv => { %>
                                <div class="card mb-3">
                                    <% if (bv.firstImage && bv.firstImage !== '/images/noimage.png') { %>
                                        <img src="<%- bv.firstImage %>" alt="<%= bv.TieuDe %>" class="card-img-top" style="max-height: 200px; object-fit: cover;" onerror="this.src='/images/noimage.png'">
                                    <% } %>
                                    <div class="card-body">
                                        <h5 class="card-title"><a href="/baiviet/<%= bv._id %>" class="text-decoration-none"><%= bv.TieuDe %></a></h5>
                                        <p class="card-text"><%= bv.TomTat %></p>
                                        <p class="card-text"><small class="text-muted">
                                            Chủ đề: <%= bv.ChuDe ? bv.ChuDe.TenChuDe : 'N/A' %> | 
                                            Tác giả: <%= bv.TaiKhoan ? bv.TaiKhoan.TenDangNhap : 'N/A' %> | 
                                            Ngày đăng: <%= new Date(bv.NgayDang).toLocaleDateString('vi-VN') %> | 
                                            Lượt xem: <%= bv.LuotXem %>
                                        </small></p>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>Không có bài viết nào.</p>
                        <% } %>
                    </div>
                    <div class="col-md-4">
                        <h4>Chủ đề</h4>
                        <div class="mb-4">
                            <% if (chuyenmuc && chuyenmuc.length > 0) { %>
                                <% chuyenmuc.forEach(cm => { %>
                                    <a href="/chude/<%= cm._id %>" class="badge bg-primary text-decoration-none me-2 mb-2"><%= cm.TenChuDe %></a>
                                <% }); %>
                            <% } else { %>
                                <p>Không có chủ đề nào.</p>
                            <% } %>
                        </div>
                        <h4>Bài viết xem nhiều</h4>
                        <% if (xemnhieu && xemnhieu.length > 0) { %>
                            <% xemnhieu.forEach(xn => { %>
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <h6 class="card-title"><a href="/baiviet/<%= xn._id %>" class="text-decoration-none"><%= xn.TieuDe %></a></h6>
                                        <p class="card-text"><small class="text-muted">Lượt xem: <%= xn.LuotXem %></small></p>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>Không có bài viết nào.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <%- include('footer') %>
    </div>

    <!-- Java Script -->
    <%- include('javascript')%>
</body>

</html>
